# Database (same Managed Postgres as Talkspresso)
DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require

# API auth
API_TOKEN=your-secret-token-here

# Server
PORT=3100

# Email (Google Workspace SMTP)
# Configured per sending account in the database
# App passwords generated at myaccount.google.com/apppasswords

# Environment
NODE_ENV=development
